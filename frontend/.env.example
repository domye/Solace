# ================================
# 前端环境变量配置
# ================================
# 复制此文件为 .env.local 用于本地开发

# ================================
# API 配置
# ================================
# API 基础地址（生产环境通过运行时配置注入）
# 开发时使用相对路径，由 Vite 代理到后端
VITE_API_BASE=/api/v1
VITE_IMGBED_BASE=
VITE_IMGBED_UPLOAD_TOKEN=
VITE_IMGBED_UPLOAD_CHANNEL=cfr2
VITE_IMGBED_UPLOAD_CHANNEL_NAME=
VITE_IMGBED_UPLOAD_FIELD=file
VITE_IMGBED_UPLOAD_FOLDER=Blog
VITE_IMGBED_CHUNK_THRESHOLD_MB=20
VITE_IMGBED_CHUNK_SIZE_MB=8

# 开发环境代理目标地址（仅开发时使用）
# 后端服务的地址
VITE_API_PROXY_TARGET=http://localhost:8080
